# Set default behavior to text and normalize line endings
* text=auto

# Explicitly declare text files we want to always normalize
*.py text
*.md text
*.txt text
*.json text
*.yaml text
*.yml text
*.toml text
*.html text
*.css text
*.js text
*.ts text
*.tsx text
*.jsx text
*.sh text
*.bat text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.ico binary

# Prevent CRLF conversion for files that should remain binary or executable
*.pem binary
*.p12 binary
*.key binary
*.dll binary
*.exe binary
*.so binary

# Mark package metadata files as text for consistent diffing
package.json text
README.md text
